<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla de arranque: fondo blanco con el logo MiMedicina centrado -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Logo más pequeño con margen para que se vea completo (sin recortes) -->
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center"
        android:drawable="@drawable/mimedicina_logo" />
</layer-list>
