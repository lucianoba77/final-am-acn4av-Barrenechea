# Copia este archivo a .env y rellena los valores.
# No subas .env al repositorio (ya está en .gitignore).

# Web Client ID de Google OAuth (mismo que default_web_client_id en la app Android)
GOOGLE_CLIENT_ID=938306231220-xxxxxxxx.apps.googleusercontent.com

# Client Secret del mismo cliente OAuth (desde Google Cloud Console > Credenciales)
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
